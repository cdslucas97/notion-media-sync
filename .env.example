# ======================================================================
# MODELO DE CONFIGURAÇÃO — copie este arquivo para ".env" e preencha.
#   No terminal:  cp .env.example .env   (ou copie manualmente)
# O arquivo .env contém segredos e NÃO deve ser versionado (já está no .gitignore).
# ======================================================================

# Token secreto da sua integração do Notion.
# Onde obter: https://www.notion.so/my-integrations  (começa com "ntn_" ou "secret_")
NOTION_TOKEN=

# ID da base (database) de FILMES no Notion.
# É a sequência de 32 caracteres na URL da base (veja o README, seção Configuração).
NOTION_DB_MOVIES=

# ID da base (database) de SÉRIES no Notion.
NOTION_DB_SERIES=

# Chave da API do TMDB (versão 3). Usada por séries e pelo script de backup de filmes.
# Onde obter: https://www.themoviedb.org/settings/api
TMDB_API_KEY=
